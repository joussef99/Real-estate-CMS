# ═══════════════════════════════════════════════════════════════════════════════
# LIVIN SERVER - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED VARIABLES
# These must be set in all environments (development, staging, production)

# PostgreSQL connection string used by Prisma and the Express app.
# Format: postgresql://user:password@host:port/database
# Railway Example: postgresql://postgres:XXXX@containers-us-west-114.railway.app:7652/railway
DATABASE_URL="postgresql://postgres:password@localhost:5432/livin"


# JWT secret used to sign authentication tokens (minimum 32 characters).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This value must be the same across all backend instances (e.g., if you scale Railway).
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_STRING"

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL VARIABLES
# These have sensible defaults but can be overridden

# HTTP port the server listens on
# Railway sets PORT automatically in production - you can leave this commented out
PORT=5000

# Password created for the initial admin user on first boot.
# Ignored if admin account already exists. Change via admin panel after first login.
# REQUIRED in production (NODE_ENV=production) — the "admin123" default below is dev-only.
ADMIN_INITIAL_PASSWORD="admin123"

# Set to 'production' in Railway for stricter logging and error handling.
# Use 'development' for local testing with detailed query logging.
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call the API.
# Development example: http://localhost:5173,http://localhost:3000
# Production example: https://livin.com,https://www.livin.com,https://admin.livin.com
# REQUIRED in production — if unset, dev mode allows ALL origins, which the server
# will now refuse to start with when NODE_ENV=production.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Optional absolute backend URL used when returning image URLs to clients.
# Only needed if your frontend and backend are on separate domains.
# Examples:
#   - https://api.livin.com
#   - https://your-backend.up.railway.app
#   - https://backend.hostinger.com
# If not set, the server infers the URL from request headers.
BACKEND_URL=https://real-estate-cms-production.up.railway.app/

# Cloudinary credentials used for persistent image uploads.
# Get these from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_CLOUDINARY_API_SECRET

# Resend API key + inbox for admin email notifications (new lead / new resale
# submission). Get a key at resend.com. Notifications are silently disabled
# (with a one-time startup warning) if either of these is left unset.
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
ADMIN_NOTIFICATION_EMAIL=REPLACE_WITH_YOUR_INBOX@example.com
# Sandbox sender works without a verified domain; swap in your own once verified.
RESEND_FROM_EMAIL="Livin Investments <onboarding@resend.dev>"

# Claude API key used to auto-translate blog posts into Egyptian colloquial
# Arabic on save. Get one at console.anthropic.com. Auto-translation is
# silently disabled (content saves normally, Arabic fields left blank) if unset.
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════

# For Railway deployment, ensure you have set:
# 1. DATABASE_URL - PostgreSQL connection string from Railway
# 2. JWT_SECRET - Generate a secure random string (min 32 chars)
# 3. ADMIN_INITIAL_PASSWORD - Set a strong password (REQUIRED in production)
# 4. NODE_ENV=production
# 5. CORS_ORIGIN - Your frontend domain(s) (REQUIRED in production)
# 6. BACKEND_URL - Your Railway backend URL
# 7. CLOUDINARY_CLOUD_NAME - Cloudinary cloud name
# 8. CLOUDINARY_API_KEY - Cloudinary API key
# 9. CLOUDINARY_API_SECRET - Cloudinary API secret
# 10. RESEND_API_KEY / ADMIN_NOTIFICATION_EMAIL - to receive lead/resale email alerts

# The server will print validation results at startup:
#   [STARTUP] Environment configuration validated:
#     NODE_ENV: production
#     PORT: (from Railway)
#     DATABASE: postgresql://...
#     JWT_SECRET: ****...****
#     CORS_ORIGIN: https://your-domain.com
#     BACKEND_URL: https://your-backend.up.railway.app

# If any required variable is missing, the server will print detailed instructions
# and exit with error code 1.
