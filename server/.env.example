# Server Configuration
# Railway injects PORT automatically in production. Keep this only for local development.
PORT=5000

# PostgreSQL connection string used by Prisma and the Express app.
# Set this to the Railway Postgres URL in production.
DATABASE_URL="postgresql://postgres:password@localhost:5432/livin"

# JWT secret used to sign auth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_STRING"

# Password created for the initial admin user on first boot.
ADMIN_INITIAL_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# Set to production on Railway.
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call the API.
# Example production value: https://livin.com,https://www.livin.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Optional absolute backend URL used when returning image URLs across domains.
# Example: https://your-backend.up.railway.app
BACKEND_URL=
