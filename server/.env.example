# Server Configuration
# HTTP port the Express server listens on (default: 5000 in split structure)
PORT=5000

# PostgreSQL connection string (Railway)
# Example: postgresql://postgres:password@host:5432/railway
DATABASE_URL="postgresql://postgres:password@localhost:5432/livin"

# JWT_SECRET: A random 256-bit hex string used to sign auth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED — server will refuse to start if this is not set.
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_STRING"

# ADMIN_INITIAL_PASSWORD: Password set for the 'admin' user on first run.
# If the admin account already exists this value is ignored.
# Change the password via the admin panel after first login.
ADMIN_INITIAL_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# NODE_ENV: Set to 'production' for production deployment
NODE_ENV=development

# CORS_ORIGIN: Frontend URL allowed to make requests to this server
# Multiple origins can be separated by commas
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# BACKEND_URL: (Optional) Full backend URL for generating absolute image URLs
# Required in production when frontend and backend are on different domains
# Example: https://api.yourdomain.com or https://your-backend.up.railway.app
# If not set, the server will infer the URL from request headers
# BACKEND_URL=https://your-backend-url.com

# NODE_ENV=production enables stricter runtime behavior
# Railway sets PORT automatically; do not hardcode in production.
