# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── Required for production ─────────────────────────────────────────────────

# JWT_SECRET: A random 256-bit hex string used to sign auth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED — server will refuse to start if this is not set.
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_STRING"

# ADMIN_INITIAL_PASSWORD: Password set for the 'admin' user on first run.
# If the admin account already exists this value is ignored.
# Change the password via the admin panel after first login.
ADMIN_INITIAL_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# PORT: HTTP port the Express server listens on (default: 3000)
PORT=3000

# NODE_ENV: Set to 'production' to serve the compiled Vite build.
NODE_ENV=production
